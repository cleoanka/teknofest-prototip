# ── Ortam değişkenleri (kopyala -> .env) ──
# YZ modu: auto = kütüphane varsa gerçek model, yoksa mock. (auto | real | mock)
AI_MODE=auto

# Model profilleri (Mac'te ultralytics otomatik MPS kullanır)
YOLO_MODEL_NORMAL=yolov8n.pt
YOLO_MODEL_CRITICAL=yolov8s.pt
YOLO_DEVICE=auto            # auto | cpu | mps | cuda

# QoD tetik motoru
QOD_EVAL_PERIOD_MS=500
QOD_BBOX_GROWTH_THRESHOLD=0.18
QOD_LOW_CONF_THRESHOLD=0.55
QOD_OCR_CONF_THRESHOLD=0.75
QOD_RELEASE_CONF=0.85
QOD_MAX_SESSION_S=5

# Mock CAMARA 5G simülatörü
CAMARA_QOD_NORMAL_MBPS=5
CAMARA_QOD_CRITICAL_MBPS=20
CAMARA_NETWORK_LATENCY_MS=60

# ── CAMARA Gerçek API (Turkcell sandbox erişimi gelince doldur) ──────────────
# mock → real geçiş için sadece bu 4 değişkeni değiştir, kod değişmez
CAMARA_MODE=mock                         # mock | real
CAMARA_BASE_URL=                         # https://opengateway.turkcell.com.tr
CAMARA_CLIENT_ID=                        # Turkcell sandbox client ID
CAMARA_CLIENT_SECRET=                    # Turkcell sandbox secret

# ── JWT RS256 Kimlik Doğrulama (ÖTR zorunlusu) ───────────────────────────────
REQUIRE_AUTH=false                       # true → tüm /api/* Bearer token zorunlu
JWT_TTL_S=3600                           # Token geçerlilik süresi (saniye)

# ── Rate limiting (ÖTR: 100 req/dak) ─────────────────────────────────────────
RATE_LIMIT=100                           # req/minute per IP

# ── WebSocket ─────────────────────────────────────────────────────────────────
WS_MAX_FRAME_BYTES=5242880               # 5 MB

# Sunucu
HOST=0.0.0.0
PORT=8000
DB_PATH=events.sqlite3
